{"surah":109,"verses":[{"n":1,"key":"109:1","arabic":" قُلْ يَـٰٓأَيُّهَا ٱلْكَـٰفِرُونَ","page":603,"juz":30,"en":"Say, \"O disbelievers,","id":"Katakanlah (Muhammad), \"Wahai orang-orang kafir!","words":[{"a":"قُلْ","en":"Say","id":"katakanlah"},{"a":"يَـٰٓأَيُّهَا","en":"O","id":"wahai"},{"a":"ٱلْكَـٰفِرُونَ","en":"disbelievers","id":"orang-orang kafir"}]},{"n":2,"key":"109:2","arabic":"لَآ أَعْبُدُ مَا تَعْبُدُونَ","page":603,"juz":30,"en":"I do not worship what you worship.","id":"aku tidak akan menyembah apa yang kamu sembah,","words":[{"a":"لَآ","en":"Not","id":"tidak"},{"a":"أَعْبُدُ","en":"I worship","id":"aku menyembah"},{"a":"مَا","en":"what","id":"apa"},{"a":"تَعْبُدُونَ","en":"you worship","id":"kamu sembah"}]},{"n":3,"key":"109:3","arabic":"وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ","page":603,"juz":30,"en":"Nor are you worshippers of what I worship.","id":"dan kamu bukan penyembah apa yang aku sembah,","words":[{"a":"وَلَآ","en":"And not","id":"dan tidak"},{"a":"أَنتُمْ","en":"you","id":"kamu"},{"a":"عَـٰبِدُونَ","en":"(are) worshippers","id":"menyembah"},{"a":"مَآ","en":"(of) what","id":"apa"},{"a":"أَعْبُدُ","en":"I worship","id":"aku sembah"}]},{"n":4,"key":"109:4","arabic":"وَلَآ أَنَا۠ عَابِدٌ مَّا عَبَدتُّمْ","page":603,"juz":30,"en":"Nor will I be a worshipper of what you worship.","id":"dan aku tidak pernah menjadi penyembah apa yang kamu sembah,","words":[{"a":"وَلَآ","en":"And not","id":"dan bukanlah"},{"a":"أَنَا۠","en":"I am","id":"aku"},{"a":"عَابِدٌۭ","en":"a worshipper","id":"menjadi penyembah"},{"a":"مَّا","en":"(of) what","id":"apa"},{"a":"عَبَدتُّمْ","en":"you worship","id":"kamu sembah"}]},{"n":5,"key":"109:5","arabic":"وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ","page":603,"juz":30,"en":"Nor will you be worshippers of what I worship.","id":"dan kamu tidak pernah (pula) menjadi penyembah apa yang aku sembah.","words":[{"a":"وَلَآ","en":"And not","id":"dan bukanlah"},{"a":"أَنتُمْ","en":"you","id":"kamu"},{"a":"عَـٰبِدُونَ","en":"(are) worshippers","id":"menyembah"},{"a":"مَآ","en":"(of) what","id":"apa"},{"a":"أَعْبُدُ","en":"I worship","id":"aku sembah"}]},{"n":6,"key":"109:6","arabic":"لَكُمْ دِينُكُمْ وَلِىَ دِينِ","page":603,"juz":30,"en":"For you is your religion, and for me is my religion.\"","id":"Untukmu agamamu, dan untukku agamaku.\"","words":[{"a":"لَكُمْ","en":"For you","id":"bagi kalian"},{"a":"دِينُكُمْ","en":"(is) your religion","id":"agamamu"},{"a":"وَلِىَ","en":"and for me","id":"bagiku"},{"a":"دِينِ","en":"(is) my religion","id":"agamaku"}]}]}