{"surah":113,"verses":[{"n":1,"key":"113:1","arabic":" قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ","page":604,"juz":30,"en":"Say, \"I seek refuge in the Lord of daybreak","id":"Katakanlah, \"Aku berlindung kepada Tuhan yang menguasai subuh (fajar),","words":[{"a":"قُلْ","en":"Say","id":"katakanlah"},{"a":"أَعُوذُ","en":"I seek refuge","id":"aku berlindung"},{"a":"بِرَبِّ","en":"in (the) Lord","id":"Tuhan/Pemelihara"},{"a":"ٱلْفَلَقِ","en":"(of) the dawn","id":"subuh"}]},{"n":2,"key":"113:2","arabic":"مِن شَرِّ مَا خَلَقَ","page":604,"juz":30,"en":"From the evil of that which He created","id":"dari kejahatan (makhluk yang) Dia ciptakan,","words":[{"a":"مِن","en":"From","id":"dari"},{"a":"شَرِّ","en":"(the) evil","id":"kejahatan"},{"a":"مَا","en":"(of) what","id":"apa"},{"a":"خَلَقَ","en":"He created","id":"Dia ciptakan"}]},{"n":3,"key":"113:3","arabic":"وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ","page":604,"juz":30,"en":"And from the evil of darkness when it settles","id":"dan dari kejahatan malam apabila telah gelap gulita,","words":[{"a":"وَمِن","en":"And from","id":"dan dari"},{"a":"شَرِّ","en":"(the) evil","id":"kejahatan"},{"a":"غَاسِقٍ","en":"(of) darkness","id":"malam yang gelap"},{"a":"إِذَا","en":"when","id":"apabila"},{"a":"وَقَبَ","en":"it spreads","id":"telah gelap/kelam"}]},{"n":4,"key":"113:4","arabic":"وَمِن شَرِّ ٱلنَّفَّـٰثَـٰتِ فِى ٱلْعُقَدِ","page":604,"juz":30,"en":"And from the evil of the blowers in knots","id":"dan dari kejahatan (perempuan-perempuan) penyihir yang meniup pada buhul-buhul (talinya),","words":[{"a":"وَمِن","en":"And from","id":"dan dari"},{"a":"شَرِّ","en":"(the) evil","id":"kejahatan"},{"a":"ٱلنَّفَّـٰثَـٰتِ","en":"(of) the blowers","id":"orang yang meniup-niup"},{"a":"فِى","en":"in","id":"dalam"},{"a":"ٱلْعُقَدِ","en":"the knots","id":"ikatan/simpul"}]},{"n":5,"key":"113:5","arabic":"وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ","page":604,"juz":30,"en":"And from the evil of an envier when he envies.\"","id":"dan dari kejahatan orang yang dengki apabila dia dengki.\"","words":[{"a":"وَمِن","en":"And from","id":"dan dari"},{"a":"شَرِّ","en":"(the) evil","id":"kejahatan"},{"a":"حَاسِدٍ","en":"(of) an envier","id":"orang yang dengki"},{"a":"إِذَا","en":"when","id":"apabila"},{"a":"حَسَدَ","en":"he envies","id":"ia dengki"}]}]}