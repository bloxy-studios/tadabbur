{"surah":114,"verses":[{"n":1,"key":"114:1","arabic":" قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ","page":604,"juz":30,"en":"Say, \"I seek refuge in the Lord of mankind,","id":"Katakanlah, \"Aku berlindung kepada Tuhannya manusia,"},{"n":2,"key":"114:2","arabic":"مَلِكِ ٱلنَّاسِ","page":604,"juz":30,"en":"The Sovereign of mankind,","id":"Raja manusia,"},{"n":3,"key":"114:3","arabic":"إِلَـٰهِ ٱلنَّاسِ","page":604,"juz":30,"en":"The God of mankind,","id":"sembahan manusia,"},{"n":4,"key":"114:4","arabic":"مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ","page":604,"juz":30,"en":"From the evil of the retreating whisperer -","id":"dari kejahatan (bisikan) setan yang bersembunyi,"},{"n":5,"key":"114:5","arabic":"ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ","page":604,"juz":30,"en":"Who whispers [evil] into the breasts of mankind -","id":"yang membisikkan (kejahatan) ke dalam dada manusia,"},{"n":6,"key":"114:6","arabic":"مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ","page":604,"juz":30,"en":"From among the jinn and mankind\".","id":"dari (golongan) jin dan manusia.\""}]}