{"surah":1,"verses":[{"n":1,"key":"1:1","arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ","page":1,"juz":1,"en":"In the name of Allāh, the Entirely Merciful, the Especially Merciful.","id":"Dengan nama Allah Yang Maha Pengasih, Maha Penyayang.","words":[{"a":"بِسْمِ","en":"In (the) name","id":"dengan nama"},{"a":"ٱللَّهِ","en":"(of) Allah","id":"Allah"},{"a":"ٱلرَّحْمَـٰنِ","en":"the Most Gracious","id":"Maha Pengasih"},{"a":"ٱلرَّحِيمِ","en":"the Most Merciful","id":"Maha Penyayang"}]},{"n":2,"key":"1:2","arabic":"ٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَـٰلَمِينَ","page":1,"juz":1,"en":"[All] praise is [due] to Allāh, Lord of the worlds -","id":"Segala puji bagi Allah, Tuhan seluruh alam,","words":[{"a":"ٱلْحَمْدُ","en":"All praises and thanks","id":"pujian"},{"a":"لِلَّهِ","en":"(be) to Allah","id":"bagi Allah"},{"a":"رَبِّ","en":"the Lord","id":"Tuhan"},{"a":"ٱلْعَـٰلَمِينَ","en":"of the universe","id":"alam semesta"}]},{"n":3,"key":"1:3","arabic":"ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ","page":1,"juz":1,"en":"The Entirely Merciful, the Especially Merciful,","id":"Yang Maha Pengasih, Maha Penyayang,","words":[{"a":"ٱلرَّحْمَـٰنِ","en":"The Most Gracious","id":"Maha Pengasih"},{"a":"ٱلرَّحِيمِ","en":"the Most Merciful","id":"Maha Penyayang"}]},{"n":4,"key":"1:4","arabic":"مَـٰلِكِ يَوْمِ ٱلدِّينِ","page":1,"juz":1,"en":"Sovereign of the Day of Recompense.","id":"Pemilik hari pembalasan.","words":[{"a":"مَـٰلِكِ","en":"(The) Master","id":"Penguasa"},{"a":"يَوْمِ","en":"(of the) Day","id":"hari"},{"a":"ٱلدِّينِ","en":"(of the) Judgment","id":"pembalasan"}]},{"n":5,"key":"1:5","arabic":"إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ","page":1,"juz":1,"en":"It is You we worship and You we ask for help.","id":"Hanya kepada Engkaulah kami menyembah dan hanya kepada Engkaulah kami mohon pertolongan.","words":[{"a":"إِيَّاكَ","en":"You Alone","id":"hanya kepadaMu"},{"a":"نَعْبُدُ","en":"we worship","id":"kami menyembah"},{"a":"وَإِيَّاكَ","en":"and You Alone","id":"dan hanya kepadaMu"},{"a":"نَسْتَعِينُ","en":"we ask for help","id":"kami mohon pertolongan"}]},{"n":6,"key":"1:6","arabic":"ٱهْدِنَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ","page":1,"juz":1,"en":"Guide us to the straight path -","id":"Tunjukilah kami jalan yang lurus,","words":[{"a":"ٱهْدِنَا","en":"Guide us","id":"tunjukkan kami"},{"a":"ٱلصِّرَٰطَ","en":"(to) the path","id":"jalan"},{"a":"ٱلْمُسْتَقِيمَ","en":"the straight","id":"lurus"}]},{"n":7,"key":"1:7","arabic":"صِرَٰطَ ٱلَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ ٱلْمَغْضُوبِ عَلَيْهِمْ وَلَا ٱلضَّآلِّينَ","page":1,"juz":1,"en":"The path of those upon whom You have bestowed favor, not of those who have earned [Your] anger or of those who are astray.","id":"(yaitu) jalan orang-orang yang telah Engkau beri nikmat kepadanya; bukan (jalan) mereka yang dimurkai, dan bukan (pula jalan) mereka yang sesat.","words":[{"a":"صِرَٰطَ","en":"(The) path","id":"jalan"},{"a":"ٱلَّذِينَ","en":"(of) those","id":"orang-orang yang"},{"a":"أَنْعَمْتَ","en":"You have bestowed (Your) Favors","id":"diberi nikmat"},{"a":"عَلَيْهِمْ","en":"on them","id":"kepadanya"},{"a":"غَيْرِ","en":"not (of)","id":"bukan"},{"a":"ٱلْمَغْضُوبِ","en":"those who earned (Your) wrath","id":"orang yang dimurkai"},{"a":"عَلَيْهِمْ","en":"on themselves","id":"kepadanya"},{"a":"وَلَا","en":"and not","id":"dan tidak"},{"a":"ٱلضَّآلِّينَ","en":"(of) those who go astray","id":"orang-orang yang sesat"}]}]}