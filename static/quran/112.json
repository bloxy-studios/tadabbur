{"surah":112,"verses":[{"n":1,"key":"112:1","arabic":" قُلْ هُوَ ٱللَّهُ أَحَدٌ","page":604,"juz":30,"en":"Say, \"He is Allāh, [who is] One,","id":"Katakanlah (Muhammad), \"Dialah Allah, Yang Maha Esa.","words":[{"a":"قُلْ","en":"Say","id":"katakanlah"},{"a":"هُوَ","en":"He","id":"Dia"},{"a":"ٱللَّهُ","en":"(is) Allah","id":"Allah"},{"a":"أَحَدٌ","en":"the One","id":"Esa"}]},{"n":2,"key":"112:2","arabic":"ٱللَّهُ ٱلصَّمَدُ","page":604,"juz":30,"en":"Allāh, the Eternal Refuge.","id":"Allah tempat meminta segala sesuatu.","words":[{"a":"ٱللَّهُ","en":"Allah","id":"Allah"},{"a":"ٱلصَّمَدُ","en":"the Eternal, the Absolute","id":"tempat bergantung"}]},{"n":3,"key":"112:3","arabic":"لَمْ يَلِدْ وَلَمْ يُولَدْ","page":604,"juz":30,"en":"He neither begets nor is born,","id":"(Allah) tidak beranak dan tidak pula diperanakkan.","words":[{"a":"لَمْ","en":"Not","id":"tidak"},{"a":"يَلِدْ","en":"He begets","id":"beranak"},{"a":"وَلَمْ","en":"and not","id":"dan tidak"},{"a":"يُولَدْ","en":"He is begotten","id":"diperanakkan"}]},{"n":4,"key":"112:4","arabic":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ","page":604,"juz":30,"en":"Nor is there to Him any equivalent.\"","id":"Dan tidak ada sesuatu yang setara dengan Dia.\"","words":[{"a":"وَلَمْ","en":"And not","id":"dan tidak"},{"a":"يَكُن","en":"is","id":"ada"},{"a":"لَّهُۥ","en":"for Him","id":"baginya"},{"a":"كُفُوًا","en":"equivalent","id":"menyamai/setara"},{"a":"أَحَدٌۢ","en":"any [one]","id":"seorang"}]}]}