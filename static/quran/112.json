{"surah":112,"verses":[{"n":1,"key":"112:1","arabic":" قُلْ هُوَ ٱللَّهُ أَحَدٌ","page":604,"juz":30,"en":"Say, \"He is Allāh, [who is] One,","id":"Katakanlah (Muhammad), \"Dialah Allah, Yang Maha Esa."},{"n":2,"key":"112:2","arabic":"ٱللَّهُ ٱلصَّمَدُ","page":604,"juz":30,"en":"Allāh, the Eternal Refuge.","id":"Allah tempat meminta segala sesuatu."},{"n":3,"key":"112:3","arabic":"لَمْ يَلِدْ وَلَمْ يُولَدْ","page":604,"juz":30,"en":"He neither begets nor is born,","id":"(Allah) tidak beranak dan tidak pula diperanakkan."},{"n":4,"key":"112:4","arabic":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ","page":604,"juz":30,"en":"Nor is there to Him any equivalent.\"","id":"Dan tidak ada sesuatu yang setara dengan Dia.\""}]}