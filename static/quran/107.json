{"surah":107,"verses":[{"n":1,"key":"107:1","arabic":" أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ","page":602,"juz":30,"en":"Have you seen the one who denies the Recompense?","id":"Tahukah kamu (orang) yang mendustakan agama?","words":[{"a":"أَرَءَيْتَ","en":"Have you seen","id":"tahukah kamu"},{"a":"ٱلَّذِى","en":"the one who","id":"yang"},{"a":"يُكَذِّبُ","en":"denies","id":"dia mendustakan"},{"a":"بِٱلدِّينِ","en":"the Judgment","id":"dengan agama"}]},{"n":2,"key":"107:2","arabic":"فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ","page":602,"juz":30,"en":"For that is the one who drives away the orphan","id":"Maka itulah orang yang menghardik anak yatim,","words":[{"a":"فَذَٰلِكَ","en":"Then that","id":"maka itulah"},{"a":"ٱلَّذِى","en":"(is) the one who","id":"yang"},{"a":"يَدُعُّ","en":"repulses","id":"dia menghardik"},{"a":"ٱلْيَتِيمَ","en":"the orphan","id":"anak yatim"}]},{"n":3,"key":"107:3","arabic":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ","page":602,"juz":30,"en":"And does not encourage the feeding of the poor.","id":"dan tidak mengajak memberi makan orang miskin.","words":[{"a":"وَلَا","en":"And (does) not","id":"dan tidak"},{"a":"يَحُضُّ","en":"feel the urge","id":"menganjurkan"},{"a":"عَلَىٰ","en":"to","id":"atas"},{"a":"طَعَامِ","en":"feed","id":"memberi makan"},{"a":"ٱلْمِسْكِينِ","en":"the poor","id":"orang miskin"}]},{"n":4,"key":"107:4","arabic":"فَوَيْلٌ لِّلْمُصَلِّينَ","page":602,"juz":30,"en":"So woe to those who pray","id":"Maka celakalah orang yang salat,","words":[{"a":"فَوَيْلٌۭ","en":"So woe","id":"maka celakalah"},{"a":"لِّلْمُصَلِّينَ","en":"to those who pray","id":"orang yang sholat"}]},{"n":5,"key":"107:5","arabic":"ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ","page":602,"juz":30,"en":"[But] who are heedless of their prayer -","id":"(yaitu) orang-orang yang lalai terhadap salatnya,","words":[{"a":"ٱلَّذِينَ","en":"Those who","id":"orang-orang yang"},{"a":"هُمْ","en":"[they]","id":"mereka"},{"a":"عَن","en":"about","id":"dar"},{"a":"صَلَاتِهِمْ","en":"their prayers","id":"sholat mereka"},{"a":"سَاهُونَ","en":"(are) neglectful","id":"lalai"}]},{"n":6,"key":"107:6","arabic":"ٱلَّذِينَ هُمْ يُرَآءُونَ","page":602,"juz":30,"en":"Those who make show [of their deeds]","id":"yang berbuat riya`,","words":[{"a":"ٱلَّذِينَ","en":"Those who","id":"orang-orang yang"},{"a":"هُمْ","en":"[they]","id":"mereka"},{"a":"يُرَآءُونَ","en":"make show","id":"mereka berbuat ria"}]},{"n":7,"key":"107:7","arabic":"وَيَمْنَعُونَ ٱلْمَاعُونَ","page":602,"juz":30,"en":"And withhold [simple] assistance.","id":"dan enggan (memberikan) bantuan.","words":[{"a":"وَيَمْنَعُونَ","en":"And they deny","id":"dan mereka mencegah/enggan"},{"a":"ٱلْمَاعُونَ","en":"[the] small kindnesses","id":"pertolongan"}]}]}