{"surah":96,"verses":[{"n":1,"key":"96:1","arabic":" ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ","page":597,"juz":30,"en":"Recite in the name of your Lord who created","id":"Bacalah dengan (menyebut) nama Tuhanmu yang menciptakan,","words":[{"a":"ٱقْرَأْ","en":"Read","id":"bacalah"},{"a":"بِٱسْمِ","en":"in (the) name","id":"dengan nama"},{"a":"رَبِّكَ","en":"(of) your Lord","id":"Tuhanmu"},{"a":"ٱلَّذِى","en":"the One Who","id":"yang"},{"a":"خَلَقَ","en":"created ","id":"menciptakan"}]},{"n":2,"key":"96:2","arabic":"خَلَقَ ٱلْإِنسَـٰنَ مِنْ عَلَقٍ","page":597,"juz":30,"en":"Created man from a clinging substance.","id":"Dia telah menciptakan manusia dari segumpal darah.","words":[{"a":"خَلَقَ","en":"He created","id":"menciptakan"},{"a":"ٱلْإِنسَـٰنَ","en":"man","id":"manusia"},{"a":"مِنْ","en":"from","id":"dari"},{"a":"عَلَقٍ","en":"a clinging substance","id":"segumpal darah"}]},{"n":3,"key":"96:3","arabic":"ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ","page":597,"juz":30,"en":"Recite, and your Lord is the most Generous -","id":"Bacalah, dan Tuhanmulah Yang Mahamulia.","words":[{"a":"ٱقْرَأْ","en":"Read","id":"bacalah"},{"a":"وَرَبُّكَ","en":"and your Lord","id":"dan Tuhanmu"},{"a":"ٱلْأَكْرَمُ","en":"(is) the Most Generous","id":"amat mulia"}]},{"n":4,"key":"96:4","arabic":"ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ","page":597,"juz":30,"en":"Who taught by the pen","id":"Yang mengajar (manusia) dengan pena.","words":[{"a":"ٱلَّذِى","en":"The One Who","id":"yang"},{"a":"عَلَّمَ","en":"taught","id":"Dia mengajar"},{"a":"بِٱلْقَلَمِ","en":"by the pen","id":"dengan kalam"}]},{"n":5,"key":"96:5","arabic":"عَلَّمَ ٱلْإِنسَـٰنَ مَا لَمْ يَعْلَمْ","page":597,"juz":30,"en":"Taught man that which he knew not.","id":"Dia mengajarkan manusia apa yang tidak diketahuinya.","words":[{"a":"عَلَّمَ","en":"Taught","id":"Dia mengajarkan"},{"a":"ٱلْإِنسَـٰنَ","en":"man","id":"manusia"},{"a":"مَا","en":"what","id":"apa"},{"a":"لَمْ","en":"not","id":"tidak"},{"a":"يَعْلَمْ","en":"he knew","id":"dia ketahui"}]},{"n":6,"key":"96:6","arabic":"كَلَّآ إِنَّ ٱلْإِنسَـٰنَ لَيَطْغَىٰٓ","page":597,"juz":30,"en":"No! [But] indeed, man transgresses","id":"Sekali-sekali tidak! Sungguh, manusia itu benar-benar melampaui batas,","words":[{"a":"كَلَّآ","en":"Nay","id":"sekali-kali tidak"},{"a":"إِنَّ","en":"Indeed","id":"sesungguhnya"},{"a":"ٱلْإِنسَـٰنَ","en":"man","id":"manusia"},{"a":"لَيَطْغَىٰٓ","en":"surely transgresses","id":"benar-benar melampui batas"}]},{"n":7,"key":"96:7","arabic":"أَن رَّءَاهُ ٱسْتَغْنَىٰٓ","page":597,"juz":30,"en":"Because he sees himself self-sufficient.","id":"apabila melihat dirinya serba cukup.","words":[{"a":"أَن","en":"That","id":"bahwa"},{"a":"رَّءَاهُ","en":"he sees himself","id":"ia melihatnya"},{"a":"ٱسْتَغْنَىٰٓ","en":"self-sufficient","id":"dia serba cukup"}]},{"n":8,"key":"96:8","arabic":"إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ","page":597,"juz":30,"en":"Indeed, to your Lord is the return.","id":"Sungguh, hanya kepada Tuhanmulah tempat kembali(mu).","words":[{"a":"إِنَّ","en":"Indeed","id":"sesungguhnya"},{"a":"إِلَىٰ","en":"to","id":"kepada"},{"a":"رَبِّكَ","en":"your Lord","id":"Tuhanmu"},{"a":"ٱلرُّجْعَىٰٓ","en":"(is) the return","id":"tempat kembali"}]},{"n":9,"key":"96:9","arabic":"أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ","page":597,"juz":30,"en":"Have you seen the one who forbids","id":"Bagaimana pendapatmu tentang orang yang melarang?","words":[{"a":"أَرَءَيْتَ","en":"Have you seen","id":"apakah kamu lihat/pendapatmu"},{"a":"ٱلَّذِى","en":"the one who","id":"yang/orang-orang"},{"a":"يَنْهَىٰ","en":"forbids","id":"ia melarang"}]},{"n":10,"key":"96:10","arabic":"عَبْدًا إِذَا صَلَّىٰٓ","page":597,"juz":30,"en":"A servant when he prays?","id":"seorang hamba ketika dia melaksanakan salat,","words":[{"a":"عَبْدًا","en":"A slave","id":"hamba"},{"a":"إِذَا","en":"when","id":"apabila"},{"a":"صَلَّىٰٓ","en":"he prays","id":"sholat"}]},{"n":11,"key":"96:11","arabic":"أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ","page":597,"juz":30,"en":"Have you seen if he is upon guidance","id":"bagaimana pendapatmu jika dia (yang dilarang salat itu) berada di atas kebenaran (petunjuk),","words":[{"a":"أَرَءَيْتَ","en":"Have you seen","id":"apakah kamu lihat/pendapatmu"},{"a":"إِن","en":"if","id":"jika"},{"a":"كَانَ","en":"he is","id":"adalah"},{"a":"عَلَى","en":"upon","id":"atas"},{"a":"ٱلْهُدَىٰٓ","en":"[the] guidance","id":"petunjuk"}]},{"n":12,"key":"96:12","arabic":"أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ","page":597,"juz":30,"en":"Or enjoins righteousness?","id":"atau dia menyuruh bertakwa (kepada Allah)?","words":[{"a":"أَوْ","en":"Or","id":"atau"},{"a":"أَمَرَ","en":"he enjoins","id":"dia menyuruh"},{"a":"بِٱلتَّقْوَىٰٓ","en":"[of the] righteousness","id":"dengan taqwa"}]},{"n":13,"key":"96:13","arabic":"أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ","page":598,"juz":30,"en":"Have you seen if he denies and turns away -","id":"Bagaimana pendapatmu jika dia (yang melarang) itu mendustakan dan berpaling?","words":[{"a":"أَرَءَيْتَ","en":"Have you seen","id":"apakah kamu lihat/pendapatmu"},{"a":"إِن","en":"if","id":"jika"},{"a":"كَذَّبَ","en":"he denies","id":"mendustakan"},{"a":"وَتَوَلَّىٰٓ","en":"and turns away","id":"dan dia berpaling"}]},{"n":14,"key":"96:14","arabic":"أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ","page":598,"juz":30,"en":"Does he not know that Allāh sees?","id":"Tidakkah dia mengetahui bahwa sesungguhnya Allah melihat (segala perbuatannya)?","words":[{"a":"أَلَمْ","en":"Does not","id":"apakah tidak/tidaklah"},{"a":"يَعْلَم","en":"he know","id":"dia mengetahui"},{"a":"بِأَنَّ","en":"that","id":"bahwa sesungguhnya"},{"a":"ٱللَّهَ","en":"Allah","id":"Allah"},{"a":"يَرَىٰ","en":"sees","id":"Dia melihat"}]},{"n":15,"key":"96:15","arabic":"كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ","page":598,"juz":30,"en":"No! If he does not desist, We will surely drag him by the forelock","id":"Sekali-kali tidak! Sungguh, jika dia tidak berhenti (berbuat demikian) niscaya Kami tarik ubun-ubunnya (ke dalam neraka),","words":[{"a":"كَلَّا","en":"Nay","id":"sekali-kali tidak"},{"a":"لَئِن","en":"If","id":"sungguh jika"},{"a":"لَّمْ","en":"not","id":"tidak"},{"a":"يَنتَهِ","en":"he desists","id":"dia berhenti"},{"a":"لَنَسْفَعًۢا","en":"surely We will drag him","id":"niscaya kami pegang/tarik"},{"a":"بِٱلنَّاصِيَةِ","en":"by the forelock","id":"dengan umbun-umbun"}]},{"n":16,"key":"96:16","arabic":"نَاصِيَةٍ كَـٰذِبَةٍ خَاطِئَةٍ","page":598,"juz":30,"en":"A lying, sinning forelock.","id":"(yaitu) ubun-ubun orang yang mendustakan dan durhaka.","words":[{"a":"نَاصِيَةٍۢ","en":"A forelock","id":"umbun-umbun"},{"a":"كَـٰذِبَةٍ","en":"lying","id":"pendusta"},{"a":"خَاطِئَةٍۢ","en":"sinful","id":"salah/durhaka"}]},{"n":17,"key":"96:17","arabic":"فَلْيَدْعُ نَادِيَهُۥ","page":598,"juz":30,"en":"Then let him call his associates;","id":"Maka biarlah dia memanggil golongannya (untuk menolongnya),","words":[{"a":"فَلْيَدْعُ","en":"Then let him call","id":"maka hendaklah dia memanggil"},{"a":"نَادِيَهُۥ","en":"his associates","id":"kaum/golongannya"}]},{"n":18,"key":"96:18","arabic":"سَنَدْعُ ٱلزَّبَانِيَةَ","page":598,"juz":30,"en":"We will call the angels of Hell.","id":"kelak Kami akan memanggil Malaikat Zabaniyah (penyiksa orang-orang yang berdosa)","words":[{"a":"سَنَدْعُ","en":"We will call","id":"kelak Kami memanggil"},{"a":"ٱلزَّبَانِيَةَ","en":"the Angels of Hell","id":"Zabaniyah"}]},{"n":19,"key":"96:19","arabic":"كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩","page":598,"juz":30,"en":"No! Do not obey him. But prostrate and draw near [to Allāh].","id":"sekali-kali tidak! Janganlah kamu patuh kepadanya; dan sujudlah serta dekatkanlah (dirimu kepada Allah).","words":[{"a":"كَلَّا","en":"Nay","id":"sekali-kali"},{"a":"لَا","en":"(Do) not","id":"jangan"},{"a":"تُطِعْهُ","en":"obey him","id":"kamu patuh kepadanya"},{"a":"وَٱسْجُدْ","en":"But prostrate","id":"dan sujudlah"},{"a":"وَٱقْتَرِب ۩","en":"and draw near (to Allah)","id":"dan dekatkanlah"}]}]}