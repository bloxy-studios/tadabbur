{"surah":94,"verses":[{"n":1,"key":"94:1","arabic":" أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ","page":596,"juz":30,"en":"Did We not expand for you, [O Muḥammad], your breast?","id":"Bukankah kami telah melapangkan dadamu (Muhammad)?","words":[{"a":"أَلَمْ","en":"Have not","id":"apakah tidak/bukankah"},{"a":"نَشْرَحْ","en":"We expanded","id":"Kami melapangkan"},{"a":"لَكَ","en":"for you","id":"bagimu"},{"a":"صَدْرَكَ","en":"your breast","id":"dadamu"}]},{"n":2,"key":"94:2","arabic":"وَوَضَعْنَا عَنكَ وِزْرَكَ","page":596,"juz":30,"en":"And We removed from you your burden","id":"dan kami pun telah menurunkan beban darimu,","words":[{"a":"وَوَضَعْنَا","en":"And We removed","id":"dan Kami letakkan/turunkan"},{"a":"عَنكَ","en":"from you","id":"dari kamu"},{"a":"وِزْرَكَ","en":"your burden","id":"bebanmu"}]},{"n":3,"key":"94:3","arabic":"ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ","page":597,"juz":30,"en":"Which had weighed upon your back","id":"yang memberatkan punggungmu,","words":[{"a":"ٱلَّذِىٓ","en":"Which","id":"yang"},{"a":"أَنقَضَ","en":"weighed upon","id":"memberatkan"},{"a":"ظَهْرَكَ","en":"your back","id":"punggungmu"}]},{"n":4,"key":"94:4","arabic":"وَرَفَعْنَا لَكَ ذِكْرَكَ","page":597,"juz":30,"en":"And raised high for you your repute.","id":"dan kami tinggikan sebutan (nama)mu bagimu.","words":[{"a":"وَرَفَعْنَا","en":"And We raised high","id":"dan Kami tinggikan"},{"a":"لَكَ","en":"for you","id":"bagimu"},{"a":"ذِكْرَكَ","en":"your reputation","id":"sebutanmu"}]},{"n":5,"key":"94:5","arabic":"فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا","page":597,"juz":30,"en":"For indeed, with hardship [will be] ease [i.e., relief].","id":"Maka sesungguhnya bersama kesulitan ada kemudahan,","words":[{"a":"فَإِنَّ","en":"So indeed","id":"maka sesungguhnya"},{"a":"مَعَ","en":"with","id":"beserta"},{"a":"ٱلْعُسْرِ","en":"the hardship","id":"kesulitan"},{"a":"يُسْرًا","en":"(is) ease","id":"kemudahan"}]},{"n":6,"key":"94:6","arabic":"إِنَّ مَعَ ٱلْعُسْرِ يُسْرًا","page":597,"juz":30,"en":"Indeed, with hardship [will be] ease.","id":"sesungguhnya bersama kesulitan ada kemudahan.","words":[{"a":"إِنَّ","en":"Indeed","id":"sesungguhnya"},{"a":"مَعَ","en":"with","id":"beserta"},{"a":"ٱلْعُسْرِ","en":"the hardship","id":"kesulitan"},{"a":"يُسْرًۭا","en":"(is) ease","id":"kemudahan"}]},{"n":7,"key":"94:7","arabic":"فَإِذَا فَرَغْتَ فَٱنصَبْ","page":597,"juz":30,"en":"So when you have finished [your duties], then stand up [for worship].","id":"Maka apabila engkau telah selesai (dari suatu urusan), tetaplah bekerja keras (untuk urusan yang lain),","words":[{"a":"فَإِذَا","en":"So when","id":"maka apabila"},{"a":"فَرَغْتَ","en":"you have finished","id":"kamu telah selesai"},{"a":"فَٱنصَبْ","en":"then labor hard","id":"maka kerja keraslah kamu"}]},{"n":8,"key":"94:8","arabic":"وَإِلَىٰ رَبِّكَ فَٱرْغَب","page":597,"juz":30,"en":"And to your Lord direct [your] longing.","id":"dan hanya kepada Tuhanmulah engkau berharap.","words":[{"a":"وَإِلَىٰ","en":"And to","id":"dan hanya"},{"a":"رَبِّكَ","en":"your Lord","id":"Tuhanmu"},{"a":"فَٱرْغَب","en":"turn your attention","id":"maka kamu berharap"}]}]}