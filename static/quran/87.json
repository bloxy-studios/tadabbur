{"surah":87,"verses":[{"n":1,"key":"87:1","arabic":" سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى","page":591,"juz":30,"en":"Exalt the name of your Lord, the Most High,","id":"Sucikanlah nama Tuhanmu Yang Mahatinggi,","words":[{"a":"سَبِّحِ","en":"Glorify","id":"sucikanlah"},{"a":"ٱسْمَ","en":"(the) name","id":"nama"},{"a":"رَبِّكَ","en":"(of) your Lord","id":"Tuhanmu"},{"a":"ٱلْأَعْلَى","en":"the Most High","id":"Maha Tinggi"}]},{"n":2,"key":"87:2","arabic":"ٱلَّذِى خَلَقَ فَسَوَّىٰ","page":591,"juz":30,"en":"Who created and proportioned","id":"yang menciptakan, lalu menyempurnakan (penciptaan-Nya),","words":[{"a":"ٱلَّذِى","en":"The One Who","id":"yang"},{"a":"خَلَقَ","en":"created","id":"Dia menciptakan"},{"a":"فَسَوَّىٰ","en":"then proportioned","id":"lalu Dia menyempurnakan"}]},{"n":3,"key":"87:3","arabic":"وَٱلَّذِى قَدَّرَ فَهَدَىٰ","page":591,"juz":30,"en":"And who destined and [then] guided","id":"yang menentukan kadar (masing-masing) dan memberi petunjuk,","words":[{"a":"وَٱلَّذِى","en":"And the One Who","id":"dan yang"},{"a":"قَدَّرَ","en":"measured","id":"Dia menentukan"},{"a":"فَهَدَىٰ","en":"then guided","id":"lalu Dia memberi petunjuk"}]},{"n":4,"key":"87:4","arabic":"وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ","page":591,"juz":30,"en":"And who brings out the pasture","id":"dan Yang menumbuhkan rerumputan,","words":[{"a":"وَٱلَّذِىٓ","en":"And the One Who","id":"dan yang"},{"a":"أَخْرَجَ","en":"brings forth","id":"Dia keluarkan"},{"a":"ٱلْمَرْعَىٰ","en":"the pasture","id":"rumput-rumputan"}]},{"n":5,"key":"87:5","arabic":"فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ","page":591,"juz":30,"en":"And [then] makes it black stubble.","id":"lalu dijadikan-Nya (rumput-rumput) itu kering kehitam-hitaman.","words":[{"a":"فَجَعَلَهُۥ","en":"And then makes it","id":"lalu Dia jadikannya"},{"a":"غُثَآءً","en":"stubble","id":"kering"},{"a":"أَحْوَىٰ","en":"dark","id":"kehitam-hitaman"}]},{"n":6,"key":"87:6","arabic":"سَنُقْرِئُكَ فَلَا تَنسَىٰٓ","page":591,"juz":30,"en":"We will make you recite, [O Muḥammad], and you will not forget,","id":"Kami akan membacakan (Alquran) kepadamu (Muhammad) sehingga engkau tidak akan lupa,","words":[{"a":"سَنُقْرِئُكَ","en":"We will make you recite","id":"Kami bacakan kepadamu"},{"a":"فَلَا","en":"so not","id":"maka tidak"},{"a":"تَنسَىٰٓ","en":"you will forget","id":"kamu lupa"}]},{"n":7,"key":"87:7","arabic":"إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ","page":591,"juz":30,"en":"Except what Allāh should will. Indeed, He knows what is declared and what is hidden.","id":"kecuali jika Allah menghendaki. Sungguh, Dia mengetahui yang terang dan yang tersembunyi.","words":[{"a":"إِلَّا","en":"Except","id":"kecuali"},{"a":"مَا","en":"what","id":"apa"},{"a":"شَآءَ","en":"wills","id":"dikehendaki"},{"a":"ٱللَّهُ ۚ","en":"Allah","id":"Allah"},{"a":"إِنَّهُۥ","en":"Indeed, He","id":"sesungguhnya Dia"},{"a":"يَعْلَمُ","en":"knows","id":"mengetahui"},{"a":"ٱلْجَهْرَ","en":"the manifest","id":"terang"},{"a":"وَمَا","en":"and what","id":"dan apa"},{"a":"يَخْفَىٰ","en":"is hidden","id":"tersembunyi"}]},{"n":8,"key":"87:8","arabic":"وَنُيَسِّرُكَ لِلْيُسْرَىٰ","page":591,"juz":30,"en":"And We will ease you toward ease.","id":"Dan Kami akan memudahkan bagimu ke jalan kemudahan (mencapai kebahagian dunia dan akhirat),","words":[{"a":"وَنُيَسِّرُكَ","en":"And We will ease you","id":"dan Kami memudahkan"},{"a":"لِلْيُسْرَىٰ","en":"to the ease","id":"untuk kemudahan"}]},{"n":9,"key":"87:9","arabic":"فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ","page":591,"juz":30,"en":"So remind, if the reminder should benefit;","id":"oleh sebab itu berikanlah peringatan, karena peringatan itu bermanfaat,","words":[{"a":"فَذَكِّرْ","en":"So remind","id":"maka berilah peringatan"},{"a":"إِن","en":"if","id":"sesungguhnya"},{"a":"نَّفَعَتِ","en":"benefits","id":"berguna"},{"a":"ٱلذِّكْرَىٰ","en":"the reminder","id":"peringatan"}]},{"n":10,"key":"87:10","arabic":"سَيَذَّكَّرُ مَن يَخْشَىٰ","page":591,"juz":30,"en":"He who fears [Allāh] will be reminded.","id":"orang yang takut (kepada Allah) akan mendapat pelajaran,","words":[{"a":"سَيَذَّكَّرُ","en":"He will pay heed ","id":"akan menerima peringatan"},{"a":"مَن","en":"(one) who","id":"orang yang"},{"a":"يَخْشَىٰ","en":"fears (Allah)","id":"ia takut"}]},{"n":11,"key":"87:11","arabic":"وَيَتَجَنَّبُهَا ٱلْأَشْقَى","page":592,"juz":30,"en":"But the wretched one will avoid it","id":"dan orang yang celaka (kafir) akan menjauhinya,","words":[{"a":"وَيَتَجَنَّبُهَا","en":"And will avoid it","id":"dan akan menjauhi"},{"a":"ٱلْأَشْقَى","en":"the wretched one","id":"orang yang celaka"}]},{"n":12,"key":"87:12","arabic":"ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ","page":592,"juz":30,"en":"[He] who will [enter and] burn in the greatest Fire,","id":"(yaitu) orang yang akan memasuki api yang besar (neraka),","words":[{"a":"ٱلَّذِى","en":"The one who","id":"yang"},{"a":"يَصْلَى","en":"will burn","id":"ia akan masuk"},{"a":"ٱلنَّارَ","en":"(in) the Fire","id":"api/neraka"},{"a":"ٱلْكُبْرَىٰ","en":"[the] great","id":"yang besar"}]},{"n":13,"key":"87:13","arabic":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ","page":592,"juz":30,"en":"Neither dying therein nor living.","id":"selanjutnya dia di sana tidak mati dan tidak (pula) hidup.","words":[{"a":"ثُمَّ","en":"Then","id":"kemudian"},{"a":"لَا","en":"not","id":"tidak"},{"a":"يَمُوتُ","en":"he will die","id":"ia mati"},{"a":"فِيهَا","en":"therein","id":"di dalamnya"},{"a":"وَلَا","en":"and not","id":"dan tidak"},{"a":"يَحْيَىٰ","en":"will live","id":"ia hidup"}]},{"n":14,"key":"87:14","arabic":"قَدْ أَفْلَحَ مَن تَزَكَّىٰ","page":592,"juz":30,"en":"He has certainly succeeded who purifies himself","id":"Sungguh beruntung orang yang menyucikan diri (dengan beriman),","words":[{"a":"قَدْ","en":"Certainly","id":"sungguh"},{"a":"أَفْلَحَ","en":"has succeeded","id":"beruntung"},{"a":"مَن","en":"(one) who","id":"siapa/orang"},{"a":"تَزَكَّىٰ","en":"purifies (himself)","id":"dia membersihkan diri"}]},{"n":15,"key":"87:15","arabic":"وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ","page":592,"juz":30,"en":"And mentions the name of his Lord and prays.","id":"dan mengingat nama Tuhannya, lalu dia salat.","words":[{"a":"وَذَكَرَ","en":"And remembers","id":"dan dia mengingat"},{"a":"ٱسْمَ","en":"(the) name","id":"nama"},{"a":"رَبِّهِۦ","en":"(of) his Lord","id":"Tuhannya"},{"a":"فَصَلَّىٰ","en":"and prays","id":"dan dia mendirikan sholat"}]},{"n":16,"key":"87:16","arabic":"بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا","page":592,"juz":30,"en":"But you prefer the worldly life,","id":"Sedangkan kamu (orang-orang kafir) memilih kehidupan dunia,","words":[{"a":"بَلْ","en":"Nay","id":"bahkan/tetapi"},{"a":"تُؤْثِرُونَ","en":"You prefer","id":"kamu memilih"},{"a":"ٱلْحَيَوٰةَ","en":"the life","id":"kehidupan"},{"a":"ٱلدُّنْيَا","en":"(of) the world","id":"dunia"}]},{"n":17,"key":"87:17","arabic":"وَٱلْـَٔاخِرَةُ خَيْرٌ وَأَبْقَىٰٓ","page":592,"juz":30,"en":"While the Hereafter is better and more enduring.","id":"padahal kehidupan akhirat itu lebih baik dan lebih kekal.","words":[{"a":"وَٱلْـَٔاخِرَةُ","en":"While the Hereafter","id":"dan akherat"},{"a":"خَيْرٌۭ","en":"(is) better","id":"lebih baik"},{"a":"وَأَبْقَىٰٓ","en":"and everlasting","id":"dan lebih kekal"}]},{"n":18,"key":"87:18","arabic":"إِنَّ هَـٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ","page":592,"juz":30,"en":"Indeed, this is in the former scriptures,","id":"Sesungguhnya ini terdapat dalam kitab-kitab yang dahulu,","words":[{"a":"إِنَّ","en":"Indeed","id":"sungguh"},{"a":"هَـٰذَا","en":"this","id":"ini"},{"a":"لَفِى","en":"surely (is) in","id":"benar-benar dalam"},{"a":"ٱلصُّحُفِ","en":"the Scriptures","id":"kitab-kitab"},{"a":"ٱلْأُولَىٰ","en":"[the] former","id":"terdahulu"}]},{"n":19,"key":"87:19","arabic":"صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ","page":592,"juz":30,"en":"The scriptures of Abraham and Moses.","id":"(yaitu) kitab-kitab Ibrahim dan Musa.","words":[{"a":"صُحُفِ","en":"(The) Scriptures","id":"kitab"},{"a":"إِبْرَٰهِيمَ","en":"(of) Ibrahim","id":"Ibrahim"},{"a":"وَمُوسَىٰ","en":"and Musa","id":"dan Musa"}]}]}